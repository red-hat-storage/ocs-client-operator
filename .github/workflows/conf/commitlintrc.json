{
    "extends": [
        "@commitlint/config-conventional"
    ],
    "rules": {
        "body-case": [
            0,
            "always",
            "lower-case"
        ],
        "body-leading-blank": [
            2,
            "always"
        ],
        "body-max-line-length": [
            2,
            "always",
            72
        ],
        "footer-leading-blank": [
            2,
            "always"
        ],
        "header-case": [
            0,
            "always",
            "lower-case"
        ],
        "header-max-length": [
            2,
            "always",
            72
        ],
        "signed-off-by": [
            2,
            "always",
            "Signed-off-by:"
        ],
        "subject-case": [
            0,
            "always",
            "lower-case"
        ],
        "subject-empty": [
            0,
            "never"
        ],
        "type-case": [
            0,
            "always",
            "lower-case"
        ],
        "type-empty": [
            0,
            "never"
        ],
        "type-enum": [
            0
        ],
        "subject-full-stop": [
            0
        ],
        "footer-max-line-length": [
            2,
            "always",
            72
        ]
    }
}
